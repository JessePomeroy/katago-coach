OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Defaults to Ollama when no OpenAI key is configured.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gpt-oss:20b

# SvelteKit calls this persistent bridge from /api/analyze.
KATAGO_ANALYSIS_URL=http://localhost:8719/analyze

# Used by `npm run katago:service`.
KATAGO_BIN=katago
KATAGO_CONFIG=/absolute/path/to/analysis_example.cfg
KATAGO_MODEL=/absolute/path/to/model.bin.gz
KATAGO_SERVICE_PORT=8719
KATAGO_QUERY_TIMEOUT_MS=120000
